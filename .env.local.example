# ─── Site ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://theableguide.com

# ─── Stripe ────────────────────────────────────────────────────────────────────
# Get keys from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Webhook Secret (for validating webhook events)
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create products in your Stripe Dashboard first
NEXT_PUBLIC_STRIPE_CUSTOM_PRICE_ID=price_...

# ─── Resend ─────────────────────────────────────────────────────────────────────
# Get key from: https://resend.com/api-keys
RESEND_API_KEY=re_...

# ─── Firebase ───────────────────────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps
NEXT_PUBLIC_FIREBASE_API_KEY=AIza...
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=theableguide.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=theableguide
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=theableguide.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789:web:abc123

# ─── Google Analytics 4 ─────────────────────────────────────────────────────────
# Get from: GA4 → Admin → Data Streams → Measurement ID
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# ─── Trustpilot ─────────────────────────────────────────────────────────────────
# Set to "true" ONLY after you have your Trustpilot Business account verified
# and have collected at least 5-10 reviews.
NEXT_PUBLIC_TRUSTPILOT_ENABLED=false

# ─── Cloudflare ─────────────────────────────────────────────────────────────────
# Not required in Next.js env — managed in Cloudflare dashboard (DNS / WAF / Pages)
# No env vars needed unless using Cloudflare Workers or KV.
