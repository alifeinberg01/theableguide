{
  "permissions": {
    "allow": [
      "Bash(npx create-next-app@latest . --typescript --tailwind --eslint --app --src-dir --import-alias \"@/*\" --no-turbopack --yes)",
      "Bash(cmd /c \"node --version && npm --version && npx --version\")",
      "Bash(cmd /c \"node -v 2>&1 || echo node_missing\")",
      "Bash(cmd /c \"where node 2>&1\")",
      "Bash(powershell -Command \"Get-Command node -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source; Get-Command npm -ErrorAction SilentlyContinue | Select-Object -ExpandProperty Source\")",
      "Bash(npm --version)",
      "Bash(npx --version)",
      "Bash(export PATH=\"$PATH:/c/Program Files/nodejs\")",
      "Bash(npm install:*)"
    ]
  }
}
